# Google Calendar API — Service Account credentials
# Creá una Service Account en Google Cloud Console:
#   1. Google Cloud Console → IAM & Admin → Service Accounts
#   2. Creá una cuenta con rol "Editor" en el Calendar que querés usar
#   3. Generá una clave JSON y copiá los valores abajo
#
# El calendar ID suele ser el email de la Service Account
# o un email tipo "xxxxx@group.calendar.google.com"

GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=
